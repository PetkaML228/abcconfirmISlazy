--[[
    Скрипт принудительного исключения.
    Логика: Ровно через 20 секунд после запуска игрок будет кикнут с сервера
    без каких-либо дополнительных условий.
]]

local function timedKick()
    -- Задержка в 20 секунд перед выполнением
    task.wait(960)

    local players = game:GetService("Players")
    local localPlayer = players.LocalPlayer

    -- Принудительный кик
    if localPlayer then
        localPlayer:Kick("\n[Таймер истек]\nПрошло 20 секунд с момента запуска скрипта.\nСоединение разорвано согласно заданному алгоритму.")
    end
end

-- Запуск в отдельном потоке, чтобы не мешать работе других скриптов
task.spawn(timedKick)
